---
import Layout from '../layouts/Layout.astro';
import WaveMiddle from "../components/WaveMiddle.astro";
---


<Layout>
    
    <WaveMiddle>
        <div class="relative flex flex-col md:flex-row items-center justify-center min-h-screen px-10 py-12 z-10">
            <!-- Left Info Panel -->
            <div class="bg-[var(--color-primary)] text-[var(--color-background)] p-10 md:w-1/2 rounded-t-3xl md:rounded-l-3xl md:rounded-tr-none shadow-lg">
                <div class="space-y-4">
                    <!-- Call -->
                    <div class="flex items-start gap-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3l2 4H7v6h2l-2 4H5a2 2 0 01-2-2V5z" />
                        </svg>
                        <div>
                        <h3 class="text-xl font-bold mb-1">Call Us</h3>
                        <p class="text-sm">
                            Yoy Phone<br />
                            Yoy Phone
                        </p>
                        </div>
                    </div>
                
                    <!-- Location -->
                    <div class="flex items-start gap-4 pr-10">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c1.656 0 3-1.344 3-3S13.656 5 12 5 9 6.344 9 8s1.344 3 3 3zm0 2c-2.21 0-4-1.79-4-4S9.79 5 12 5s4 1.79 4 4-1.79 4-4 4zm0 2c-2.485 0-9 1.343-9 4v1h18v-1c0-2.657-6.515-4-9-4z" />
                        </svg>
                        <div>
                        <h3 class="text-xl font-bold mb-1">Location</h3>
                        <p class="text-sm">
                            this your location,<br />
                            this your location,<br />
                        </p>
                        </div>
                    </div>
                
                    <!-- Working Hours -->
                    <div class="flex items-start gap-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3M12 2a10 10 0 110 20 10 10 0 010-20z" />
                        </svg>
                        <div>
                        <h3 class="text-xl font-bold mb-1">Working Hours</h3>
                        <p class="text-sm">
                            Mon - Fri: 10am - 8pm<br />
                            Sat, Sun: Closed
                        </p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Right Form Panel -->
            <div class="bg-[var(--color-background)] p-10 md:w-1/2 rounded-b-3xl md:rounded-r-3xl md:rounded-bl-none text-[var(--color-primary)] shadow-lg ">
                <h2 class="text-2xl font-bold mb-2">Contact Us</h2>
            
                <form action="#" method="POST" class="space-y-4">
                    <div>
                        <input type="text" placeholder="Enter your Name" class="w-full border-b-2 border-[var(--color-accent)] focus:outline-none focus:bg-[var(--color-secondary)] focus:border-[var(--color-primary)] py-2 placeholder:text-[var(--color-accent)]" required>
                    </div>
                    <div>
                        <input type="email" placeholder="Enter a valid email address" class="w-full border-b-2 border-[var(--color-accent)] focus:outline-none focus:bg-[var(--color-secondary)] focus:border-[var(--color-primary)] py-2 placeholder:text-[var(--color-accent)]" required>
                    </div>
                    <div>
                        <textarea rows="4" placeholder="Your Message" class="w-full border-b-2 border-[var(--color-accent)] focus:outline-none focus:bg-[var(--color-secondary)] focus:border-[var(--color-primary)] py-2 placeholder:text-[var(--color-accent)]" required></textarea>
                    </div>
                    <div class="flex flex-wrap justify-center">
                        <a href="/contact" class="bg-[var(--color-secondary)] bg-opacity-90 justify-items-center rounded-lg p-2 hover:-translate-y-1 hover:delay-150 hover:scale-110 hover:bg-[var(--color-primary)] hover:text-[var(--color-background)] hover:bg-opacity-100 transition duration-300 flex items-center gap-1">
                        Send Message
                        <span>&rarr;</span>
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </WaveMiddle>    
</Layout>
