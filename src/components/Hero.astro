---
import WaveBackground from "../components/WaveBackground.astro";
---

<WaveBackground >
  <div class="items-center justify-center z-10 max-w-3xl text-center rounded-lg py-12 backdrop-blur-md shadow-xl" >
    <h2 class="gradient-overlay text-4xl md:text-6xl 2xl:text-8xl font-extrabold tracking-tight drop-shadow-lg mb-6">
        Software Development
    </h2>
    <p class="text-lg md:text-xl xl:text-2xl 2xl:text-3xl font-light leading-relaxed max-w-2xl mx-auto mb-4">
        We develop your website so you can be everywhere.
    </p>
    <p class="text-sm md:text-base xl:text-lg 2xl:text-xl text-[var(--color-accent)] font-light leading-relaxed max-w-2xl mx-auto mb-8">
        Trust and stability with quality 
        <span class="font-semibold text-[var(--color-primary)]">
            Web
        </span>
    </p>
    <div class="flex flex-wrap justify-center">
      <a href="/contact" class="bg-[var(--color-secondary)] text-[var(--color-background)] text-2xl bg-opacity-90 justify-items-center rounded-lg p-2 hover:-translate-y-1 hover:delay-150 hover:scale-110 hover:bg-[var(--color-primary)] hover:text-[var(--color-secondary)] hover:bg-opacity-100 transition duration-300 flex items-center gap-1">
        Contact
        <span>&rarr;</span>
      </a>
    </div>
  </div>
</WaveBackground>

<style>
    .gradient-overlay {
      background: linear-gradient(
        45deg,
        var(--color-primary),
        var(--color-secondary),
        var(--color-background),
        var(--color-secondary),
        var(--color-primary)
      );
      -webkit-background-clip: text;
      background-size: 300% 300%;
      background-clip: text;
      color : transparent;
      text-transform: uppercase;
      animation: gradient 5s ease infinite;
    }
  
    @keyframes gradient {
      0% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0% 50%;
      }
    }
</style>
