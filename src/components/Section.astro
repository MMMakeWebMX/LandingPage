---
import WaveBackgroundInvert from "../components/WaveBackgroundInvert.astro";
---

<WaveBackgroundInvert >
    <div class="flex items-center justify-center min-h-screen px-10 py-12">
        <div class="w-full max-w-5xl  relative overflow-hidden rounded-4xl backdrop-blur-md shadow-lg p-6 md:p-12 flex flex-col md:flex-row items-center justify-between gap-6">
        
        <!-- Imagen que se sale un poco -->
        <div class="relative flex-shrink-0 -mt-12 md:-mt-20">
            <img src="../people.webp" alt="People" class="rounded-4xl h-60 md:h-72 lg:h-80 w-auto drop-shadow-2xl" />
            <div class="absolute -top-6 -right-6 w-20 h-20 rounded-full blur-3xl opacity-30 z-[-1]"></div>
        </div>
        
        <!-- Texto -->
        <div class="flex-1 max-w-2xl text-[var(--color-accent)]">
            <h2 class="text-4xl font-bold mb-4 leading-tight text-[var(--color-primary)]">
            Section Collection
            </h2>
            <p class="text-lg leading-relaxed mb-4">
            This section provides additional information about what we do and how we can help. Whether you're looking for inspiration, guidance, or specific solutions, you're in the right place.
            </p>
            <p class="text-md leading-relaxed">
            Discover our latest updates, learn more about our team, and see how we bring value to every project. Explore the services we offer and feel free to get in touch for personalized support.
            </p>
        </div>
        
        </div>
    </div>

  
</WaveBackgroundInvert>


