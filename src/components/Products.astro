---
import Card from '../components/Card.astro';
---

<section id="section" class="section md:h-screen h-dvh flex items-center justify-center px-10 z-1">
    <div class=" relative flex flex-col items-center justify-center text-[var(--color-accent)]" >
        <h2 class="text-2xl md:text-3xl xl:text-4xl font-bold mt-10 text-[var(--color-primary)]">
            Trending Collection
        </h2>
        <p class="text-lg md:text-xl xl:text-2xl pb-10  font-light leading-relaxed">
            This section provides additional information about the page. 
        </p>

        <div class="flex flex-col pb-10 md:pb-0 md:grid md:grid-cols-3 gap-12 md:gap-8 space-y-4 md:space-y-0">
            <Card title="Products" img="../image1.webp" href="" />
            <Card title="Images" img="../image2.webp" href="" />
            <Card title="Services" img="../image3.webp" href="" />
        </div>
    </div>
</section>
